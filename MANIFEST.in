# Include documentation
include README.md
include LICENSE
include CONTRIBUTING.md

# Include type stubs
recursive-include src/dazzle py.typed *.pyi

# Include templates
recursive-include src/dazzle/templates *.dsl *.toml *.md .gitignore

# Include UI runtime static files (JS, CSS). Path updated by #1055
# (v0.67.98) — dazzle_ui nested under dazzle.ui.
recursive-include src/dazzle/ui/runtime/static *.js *.css

# Include LSP grammar files
recursive-include src/dazzle/lsp/grammars *.json

# Include test data but not test code
recursive-include tests/fixtures *.dsl *.toml

# Exclude
global-exclude *.pyc
global-exclude *.pyo
global-exclude __pycache__
global-exclude .DS_Store
global-exclude *.so
global-exclude *.map
