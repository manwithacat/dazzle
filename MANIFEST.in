# Include documentation
include README.md
include LICENSE
include CONTRIBUTING.md

# Include type stubs
recursive-include src/dazzle py.typed *.pyi

# Include templates
recursive-include src/dazzle/templates *.dsl *.toml *.md .gitignore

# Include UI runtime static files (JS, CSS, fonts). Path updated by #1055
# (v0.67.98) — dazzle_page nested under dazzle.page. woff2 + OFL.txt added by
# #1572: the vendored Geist fonts were silently dropped from distributions
# (OFL 1.1 requires the licence to accompany font distribution).
recursive-include src/dazzle/page/runtime/static *.js *.css *.mjs *.woff2 OFL.txt

# Include LSP grammar files
recursive-include src/dazzle/lsp/grammars *.json

# Agent-command definition TOMLs (#1589) — wheel inclusion via package-data;
# sdist needs the recursive-include so `python -m build` sees them.
recursive-include src/dazzle/services/agent_commands/definitions *.toml

# Include Alembic migration assets (#1308) — the `dazzle db` CLI loads these by
# file path (script.py.mako template, alembic.ini, and the framework baseline
# migrations under versions/, which is not a Python package). Needed in the
# sdist; the wheel inclusion is handled by [tool.setuptools.package-data].
recursive-include src/dazzle/http/alembic *.mako *.ini *.py

# Include test data but not test code
recursive-include tests/fixtures *.dsl *.toml

# Exclude
global-exclude *.pyc
global-exclude *.pyo
global-exclude __pycache__
global-exclude .DS_Store
global-exclude *.so
global-exclude *.map
