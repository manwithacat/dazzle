# Per-example secrets — template is .env.example, actual .env never committed
examples/*/.env

# Test-suite distillation classifier output (regenerable; large)
tests/audit/classification.json

# Per-project auto-generated DSL test files (regenerated by `dazzle test generate`)
**/dsl/tests/dsl_generated_tests.json

# Local OpenTelemetry trace runs from `dazzle perf trace` (#1153 follow-on).
.dazzle/perf/
PLAN.md
.github/codeql/extensions/**/.codeql/

# HaTchi-MaXchi generated site fonts (copied from vendored source) + pycache
packages/hatchi-maxchi/site/fonts/
packages/**/__pycache__/
