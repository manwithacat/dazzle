            "params": {
              "values": [
                "Device drops Wi-Fi after 12 minutes of continuous sampling in the field enclosure.",
                "Touch screen ignores taps in the lower-left quadrant after cold soak at \u22125\u00b0C.",
                "Battery indicator jumps from 40% to 5% without intermediate readings.",
                "Calibration drift exceeds \u00b12% after three outdoor test cycles.",
                "Audio alert fails to sound when temperature threshold is crossed.",
                "USB-C port only charges when the cable is oriented one way; data transfer fails.",
                "GPS lock takes >90s under light tree canopy; baseline is 20s.",
                "App freezes when exporting a 24-hour log to CSV on firmware 1.4.x."
              ]
            }
          },
          {
            "field_name": "steps_to_reproduce",
            "strategy": "static_list",
            "params": {
              "values": [
                "1) Power on unit 2) Start continuous sample 3) Wait 12 min 4) Observe disconnect",
                "1) Cold-soak overnight 2) Unlock screen 3) Tap lower-left controls repeatedly",
                "1) Charge to 50% 2) Run outdoor walk 3) Watch battery UI for jumps",
                "1) Run outdoor cal script 2) Compare to lab reference 3) Log delta",
                "1) Set threshold to ambient+2\u00b0C 2) Warm sensor 3) Confirm no audible alert",
                "1) Connect USB-C data cable 2) Attempt photo export 3) Note failure orientation",
                "1) Clear GPS cache 2) Move under trees 3) Time to first fix",
                "1) Collect 24h log 2) Tap Export CSV 3) Observe freeze"
              ]
            }
