{
  "version": "1.0",
  "blueprint": {
    "project_id": "project_tracker",
    "domain_description": "Project delivery — one flagship project with milestones and a full kanban of tasks",
    "seed": 42,
    "tenants": [
      {
        "name": "Acme Delivery",
        "slug": "acme-delivery",
        "notes": "Demo tenant"
      }
    ],
    "personas": [
      {
        "persona_name": "admin",
        "description": "Admin",
        "default_role": "admin",
        "default_user_count": 1
      },
      {
        "persona_name": "manager",
        "description": "Project manager",
        "default_role": "manager",
        "default_user_count": 1
      },
      {
        "persona_name": "member",
        "description": "Team member",
        "default_role": "member",
        "default_user_count": 4
      }
    ],
    "entities": [
      {
        "name": "User",
        "row_count_default": 0,
        "notes": "Team members from personas",
        "tenant_scoped": false,
        "field_patterns": [
          {
            "field_name": "id",
            "strategy": "uuid_generate",
            "params": {}
          },
          {
            "field_name": "email",
            "strategy": "email_from_name",
            "params": {
              "source_field": "name",
              "domains": [
                "acme.test"
              ]
            }
          },
          {
            "field_name": "name",
            "strategy": "person_name",
            "params": {
              "locale": "en_GB"
            }
          }
        ]
      },
      {
        "name": "Project",
        "row_count_default": 2,
        "notes": "Flagship projects",
        "tenant_scoped": false,
        "field_patterns": [
          {
            "field_name": "id",
            "strategy": "uuid_generate",
            "params": {}
          },
          {
            "field_name": "name",
            "strategy": "static_list",
            "params": {
              "values": [
                "Website relaunch",
                "Mobile app beta"
              ],
              "sampling": "cycle"
            }
          },
          {
            "field_name": "description",
            "strategy": "static_list",
            "params": {
              "values": [
                "Public site redesign with new IA and performance budget.",
                "iOS/Android beta for field agents."
              ],
              "sampling": "cycle"
            }
          },
          {
            "field_name": "status",
            "strategy": "static_list",
            "params": {
              "values": [
                "active"
              ]
            }
          }
        ]
      },
      {
        "name": "Milestone",
        "row_count_default": 4,
        "notes": "Milestones",
        "tenant_scoped": false,
        "field_patterns": [
          {
            "field_name": "id",
            "strategy": "uuid_generate",
            "params": {}
          },
          {
            "field_name": "parent_project",
            "strategy": "foreign_key",
            "params": {
              "target_entity": "Project"
            }
          },
          {
            "field_name": "name",
            "strategy": "static_list",
            "params": {
              "values": [
                "Discovery",
                "Design freeze",
                "Beta launch",
                "GA"
              ],
              "sampling": "cycle"
            }
          },
          {
            "field_name": "status",
            "strategy": "enum_weighted",
            "params": {
              "enum_values": [
                "planning",
                "active",
                "completed"
              ],
              "weights": [
                0.25,
                0.5,
                0.25
              ]
            }
          }
        ]
      },
      {
        "name": "Task",
        "row_count_default": 16,
        "notes": "Kanban tasks",
        "tenant_scoped": false,
        "field_patterns": [
          {
            "field_name": "id",
            "strategy": "uuid_generate",
            "params": {}
          },
          {
            "field_name": "parent_project",
            "strategy": "foreign_key",
            "params": {
              "target_entity": "Project"
            }
          },
          {
            "field_name": "title",
            "strategy": "static_list",
            "params": {
              "values": [
                "Map current IA and drop-off funnels",
                "Draft wireframes for pricing page",
                "Implement design tokens in CSS",
                "Accessibility pass on checkout",
                "Write release notes for beta",
                "Set up crash analytics",
                "Fix flaky login e2e",
                "Review vendor SLA for CDN",
                "Ship empty-state illustrations",
                "Tune list pagination performance",
                "Pair with support on top tickets",
                "Schedule design critique",
                "Cut release branch for GA",
                "Document API rate limits",
                "Migrate legacy redirects",
                "QA dark mode contrast"
              ],
              "sampling": "cycle"
            }
          },
          {
            "field_name": "status",
            "strategy": "enum_weighted",
            "params": {
              "enum_values": [
                "backlog",
                "todo",
                "in_progress",
                "review",
                "done"
              ],
              "weights": [
                0.15,
                0.25,
                0.25,
                0.15,
                0.2
              ]
            }
          },
          {
            "field_name": "priority",
            "strategy": "enum_weighted",
            "params": {
              "enum_values": [
                "low",
                "medium",
                "high",
                "critical"
              ],
              "weights": [
                0.2,
                0.4,
                0.3,
                0.1
              ]
            }
          }
        ]
      },
      {
        "name": "Comment",
        "row_count_default": 8,
        "notes": "Task comments",
        "tenant_scoped": false,
        "field_patterns": [
          {
            "field_name": "id",
            "strategy": "uuid_generate",
            "params": {}
          },
          {
            "field_name": "task",
            "strategy": "foreign_key",
            "params": {
              "target_entity": "Task"
            }
          },
          {
            "field_name": "body",
            "strategy": "static_list",
            "params": {
              "values": [
                "Blocked on legal review — ETA Friday.",
                "Pushed a draft PR; please sanity-check tokens.",
                "Customer confirmed the workaround works.",
                "Moving to review after design sign-off."
              ],
              "sampling": "cycle"
            }
          }
        ]
      }
    ]
  }
}
