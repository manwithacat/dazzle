{
  "version": "1.0",
  "blueprint": {
    "project_id": "llm_ticket_classifier",
    "domain_description": "AI-assisted support ticket classification",
    "seed": 42,
    "tenants": [
      {
        "name": "Demo SaaS",
        "slug": "demo-saas",
        "notes": "trial"
      }
    ],
    "personas": [],
    "entities": [
      {
        "name": "Ticket",
        "row_count_default": 8,
        "notes": null,
        "tenant_scoped": false,
        "field_patterns": [
          {
            "field_name": "id",
            "strategy": "uuid_generate",
            "params": {}
          },
          {
            "field_name": "subject",
            "strategy": "static_list",
            "params": {
              "values": [
                "Cannot login after password reset",
                "Double charged on monthly invoice",
                "Feature request: dark mode for dashboard",
                "API keys not working in production",
                "SSO login loop for enterprise org",
                "Export CSV times out on large projects",
                "Webhook delivery failures overnight",
                "Account owner transfer stuck pending"
              ]
            }
          },
          {
            "field_name": "description",
            "strategy": "static_list",
            "params": {
              "values": [
                "Customer reset password twice yesterday; new link always says expired. Browser Chrome 128 on Windows.",
                "Invoice #4821 charged twice on the 1st. Need refund of one charge and a corrected receipt.",
                "Several power users asked for a dark theme. Prefer system-preference toggle over a separate site.",
                "Prod API key returns 401 since Tuesday deploy. Staging key still works. Need root-cause before standup.",
                "Enterprise IdP SSO redirects back to login after Okta assert. Affects 40 seats on the Acme tenant.",
                "Project export with 50k rows never finishes; spinner for 10+ minutes then blank page.",
                "Outbound webhooks to customer CRM failed overnight with 502s. Retry queue is growing.",
                "Owner transfer form submits but status stays pending. New owner never receives invite email."
              ]
            }
          },
          {
            "field_name": "customer_email",
            "strategy": "email_from_name",
            "params": {
              "source_field": "subject",
              "domains": [
                "example.test"
              ]
            }
          },
          {
            "field_name": "status",
            "strategy": "enum_weighted",
            "params": {
              "enum_values": [
                "open",
                "in_progress",
                "resolved",
                "closed"
              ],
              "weights": [
                0.5,
                0.3,
                0.15,
                0.05
              ]
            }
          }
        ]
      },
      {
        "name": "TicketClassification",
        "row_count_default": 6,
        "notes": null,
        "tenant_scoped": false,
        "field_patterns": [
          {
            "field_name": "id",
            "strategy": "uuid_generate",
            "params": {}
          },
          {
            "field_name": "ticket",
            "strategy": "foreign_key",
            "params": {
              "target_entity": "Ticket"
            }
          },
          {
            "field_name": "category",
            "strategy": "enum_weighted",
            "params": {
              "enum_values": [
                "billing",
                "technical",
                "feature_request",
                "account",
                "other"
              ],
              "weights": [
                0.2,
                0.35,
                0.15,
                0.2,
                0.1
              ]
            }
          },
          {
            "field_name": "priority",
            "strategy": "enum_weighted",
            "params": {
              "enum_values": [
                "low",
                "medium",
                "high",
                "critical"
              ],
              "weights": [
                0.25,
                0.4,
                0.25,
                0.1
              ]
            }
          },
          {
            "field_name": "sentiment",
            "strategy": "enum_weighted",
            "params": {
              "enum_values": [
                "positive",
                "neutral",
                "negative",
                "frustrated"
              ],
              "weights": [
                0.1,
                0.3,
                0.35,
                0.25
              ]
            }
          },
          {
            "field_name": "confidence",
            "strategy": "numeric_range",
            "params": {
              "min": 0.55,
              "max": 0.98
            }
          },
          {
            "field_name": "suggested_response",
            "strategy": "static_list",
            "params": {
              "values": [
                "Thanks for reporting this \u2014 I've escalated to billing and will confirm the refund within one business day.",
                "Sorry for the login friction. Please try the reset link once more; if it fails we'll force-expire prior tokens.",
                "Logged as a feature request. We'll share an ETA after the next product triage."
              ]
            }
          },
          {
            "field_name": "llm_job_id",
            "strategy": "static_list",
            "params": {
              "values": [
                "job_cls_01",
                "job_cls_02",
                "job_cls_03",
                "job_pri_01"
              ]
            }
          }
        ]
      }
    ]
  }
}
