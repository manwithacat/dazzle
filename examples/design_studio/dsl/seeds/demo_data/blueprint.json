                0.35,
                0.25,
                0.1,
                0.1
              ]
            }
          },
          {
            "field_name": "tags",
            "strategy": "free_text_lorem",
            "params": {
              "min_words": 1,
              "max_words": 3
            }
          },
          {
            "field_name": "quality_score",
            "strategy": "numeric_range",
            "params": {
              "min": 1,
              "max": 5
            }
          }
        ]
      },
      {
        "name": "Campaign",
        "row_count_default": 3,
        "notes": null,
        "tenant_scoped": false,
        "field_patterns": [
          {
            "field_name": "id",
            "strategy": "uuid_generate",
            "params": {}
          },
          {
            "field_name": "name",
            "strategy": "free_text_lorem",
            "params": {
              "min_words": 2,
              "max_words": 5
            }
          },
          {
            "field_name": "description",
            "strategy": "free_text_lorem",
            "params": {
              "min_words": 6,
              "max_words": 18
            }
          },
          {
            "field_name": "brand",
            "strategy": "foreign_key",
            "params": {
              "target_entity": "Brand"
            }
          },
          {
            "field_name": "status",
            "strategy": "enum_weighted",
            "params": {
              "enum_values": [
                "planning",
                "active",
                "completed",
                "cancelled"
