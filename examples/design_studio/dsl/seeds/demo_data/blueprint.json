              "sampling": "cycle"
            }
          },
          {
            "field_name": "secondary_color",
            "strategy": "static_list",
            "params": {
              "values": [
                "#0F172A",
                "#2563EB",
                "#F59E0B",
                "#10B981",
                "#EF4444",
                "#7C3AED"
              ],
              "sampling": "cycle"
            }
          },
          {
            "field_name": "accent_color",
            "strategy": "static_list",
            "params": {
              "values": [
                "#0F172A",
                "#2563EB",
                "#F59E0B",
                "#10B981",
                "#EF4444",
                "#7C3AED"
              ],
              "sampling": "cycle"
            }
          }
        ]
