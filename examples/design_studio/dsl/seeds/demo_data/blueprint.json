        "row_count_default": 12,
        "notes": "Explicit Asset.jsonl: story titles + \u22654 review for Review Desk (#1626 P0-8/P0-5)",
        "tenant_scoped": false,
        "field_patterns": [
          {
            "field_name": "id",
            "strategy": "uuid_generate",
            "params": {}
          },
          {
            "field_name": "name",
            "strategy": "static_list",
