          },
          {
            "field_name": "start_date",
            "strategy": "date_relative",
            "params": {
              "anchor": "today",
              "min_offset_days": -30,
              "max_offset_days": 10
            }
          },
          {
            "field_name": "end_date",
            "strategy": "date_relative",
            "params": {
              "anchor": "today",
              "min_offset_days": 10,
              "max_offset_days": 90
            }
          },
          {
            "field_name": "budget",
            "strategy": "currency_amount",
            "params": {
              "min": 1000,
              "max": 50000
            }
          }
        ]
      },
      {
        "name": "Feedback",
        "row_count_default": 8,
        "notes": "Required reviewer FK was missing from blueprint \u2192 null reviewer 400s on managed seed reset",
        "tenant_scoped": false,
        "field_patterns": [
          {
            "field_name": "id",
            "strategy": "uuid_generate",
            "params": {}
          },
          {
            "field_name": "asset",
            "strategy": "foreign_key",
            "params": {
              "target_entity": "Asset"
            }
          },
          {
            "field_name": "reviewer",
            "strategy": "foreign_key",
            "params": {
              "target_entity": "User"
            }
