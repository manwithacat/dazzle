{
  "version": "1.0",
  "blueprint": {
    "project_id": "design_studio",
    "domain_description": "Brand and design asset management",
    "seed": 42,
    "tenants": [
      {
        "name": "Studio Demo",
        "slug": "studio-demo",
        "notes": "trial"
      }
    ],
    "personas": [],
    "entities": [
      {
        "name": "User",
        "row_count_default": 4,
        "notes": "Studio personas (admin/designer/reviewer) so Feedback.reviewer FK can resolve",
        "tenant_scoped": false,
        "field_patterns": [
          {
            "field_name": "id",
            "strategy": "uuid_generate",
            "params": {}
          },
          {
            "field_name": "email",
            "strategy": "email_from_name",
            "params": {
              "source_field": "name",
              "domains": [
                "studio.test"
              ]
            }
          },
          {
            "field_name": "name",
            "strategy": "person_name",
            "params": {
              "locale": "en_GB"
            }
          },
          {
            "field_name": "role",
            "strategy": "enum_weighted",
            "params": {
              "enum_values": [
                "admin",
                "designer",
                "reviewer"
              ],
              "weights": [
                0.25,
                0.5,
                0.25
              ]
            }
          },
          {
            "field_name": "created_at",
            "strategy": "date_relative",
            "params": {
              "anchor": "today",
              "min_offset_days": -180,
              "max_offset_days": 0
            }
          }
        ]
      },
      {
        "name": "Brand",
        "row_count_default": 4,
