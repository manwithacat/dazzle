                "Wordmark dark",
                "App icon 1024",
                "Social cover 1200\u00d7630",
                "Email header",
                "Packaging dieline v3",
                "Illustration \u2014 hero wave",
                "Icon set 24px",
                "Brand guidelines PDF",
                "Photography \u2014 storefront",
                "Motion logo loop",
