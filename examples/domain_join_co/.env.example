# Example .env for domain_join_co. Copy to .env and edit.
#
# dazzle serve reads this file automatically when launched from this
# directory (src/dazzle/cli/runtime_impl/serve.py::_load_dotenv). Shell
# exports take precedence if both are set.

# Postgres + Redis — both required.
DATABASE_URL=postgresql://localhost:5432/domain_join_co_dev
REDIS_URL=redis://localhost:6379/0

# Verified-domain join is a multi-tenant, host-routed flow. To exercise the
# tenant_host: resolution locally you map the workspace slug onto localhost
# (the join landing + announcements board live at <slug>.localhost). The
# canonical/apex host (localhost) binds no tenant. See README.md and the
# runbook docs/reference/verified-domain-join.md.

# QA mode — optional (Mode C long-running dev env with the QA panel visible).
# DAZZLE_ENV=development
# DAZZLE_QA_MODE=1
