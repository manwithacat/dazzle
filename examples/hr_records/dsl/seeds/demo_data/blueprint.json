{
  "version": "1.0",
  "blueprint": {
    "project_id": "hr_records",
    "domain_description": "HR records for Northwind \u2014 people, departments, employment and salary history",
    "seed": 42,
    "tenants": [
      {
        "name": "Northwind People",
        "slug": "northwind-people",
        "notes": "Demo company"
      }
    ],
    "personas": [
      {
        "persona_name": "hr_admin",
        "description": "HR administrator",
        "default_role": "hr_admin",
        "default_user_count": 1
      },
      {
        "persona_name": "manager",
        "description": "Line manager",
        "default_role": "manager",
        "default_user_count": 2
      },
      {
        "persona_name": "finance",
        "description": "Finance compensation",
        "default_role": "finance",
        "default_user_count": 1
      },
      {
        "persona_name": "employee",
        "description": "Employee",
        "default_role": "employee",
        "default_user_count": 8
      }
    ],
    "entities": [
      {
        "name": "Department",
        "row_count_default": 4,
        "notes": "Org departments",
        "tenant_scoped": false,
        "field_patterns": [
          {
            "field_name": "id",
            "strategy": "uuid_generate",
            "params": {}
          },
          {
            "field_name": "name",
            "strategy": "static_list",
            "params": {
              "values": [
                "Engineering",
                "Sales",
                "People Ops",
                "Finance"
              ],
              "sampling": "cycle"
            }
          }
        ]
      },
      {
        "name": "Role",
        "row_count_default": 6,
        "notes": "Job roles",
        "tenant_scoped": false,
        "field_patterns": [
          {
            "field_name": "id",
            "strategy": "uuid_generate",
            "params": {}
          },
          {
            "field_name": "title",
            "strategy": "static_list",
            "params": {
              "values": [
                "Software Engineer",
                "Senior Engineer",
                "Account Executive",
                "HR Business Partner",
                "Financial Controller",
                "Engineering Manager"
              ],
              "sampling": "cycle"
            }
          },
          {
            "field_name": "level",
            "strategy": "enum_weighted",
            "params": {
              "enum_values": [
                "ic1",
                "ic2",
                "ic3",
                "ic4",
                "ic5",
                "ic6",
                "m1",
                "m2",
                "m3",
                "m4"
              ],
              "weights": [
                0.12,
                0.15,
                0.15,
                0.12,
                0.08,
                0.05,
                0.12,
                0.1,
                0.07,
                0.04
              ]
            }
          },
          {
            "field_name": "department",
            "strategy": "foreign_key",
            "params": {
              "target_entity": "Department"
            }
          }
        ]
      },
      {
        "name": "Person",
        "row_count_default": 12,
        "notes": "Employees",
        "tenant_scoped": false,
        "field_patterns": [
          {
            "field_name": "id",
            "strategy": "uuid_generate",
            "params": {}
          },
          {
            "field_name": "legal_name",
            "strategy": "person_name",
            "params": {
              "locale": "en_GB"
            }
          },
          {
            "field_name": "preferred_name",
            "strategy": "person_name",
            "params": {
              "locale": "en_GB"
            }
          },
          {
            "field_name": "email",
            "strategy": "email_from_name",
            "params": {
              "source_field": "legal_name",
              "domains": [
                "northwind.test"
              ]
            }
          },
          {
            "field_name": "started_at",
            "strategy": "date_relative",
            "params": {
              "anchor": "today",
              "min_offset_days": -2000,
              "max_offset_days": -60
            }
          },
          {
            "field_name": "ended_at",
            "strategy": "static_list",
            "params": {
              "values": [
                null
              ],
              "sampling": "cycle"
            }
          }
        ]
      },
      {
        "name": "Employment",
        "row_count_default": 12,
        "notes": "Employment needs start_date (required); null end_date = active",
        "tenant_scoped": false,
        "field_patterns": [
          {
            "field_name": "id",
            "strategy": "uuid_generate",
            "params": {}
          },
          {
            "field_name": "person",
            "strategy": "foreign_key",
            "params": {
              "target_entity": "Person"
            }
          },
          {
            "field_name": "role",
            "strategy": "foreign_key",
            "params": {
              "target_entity": "Role"
            }
          },
          {
            "field_name": "department",
            "strategy": "foreign_key",
            "params": {
              "target_entity": "Department"
            }
          },
          {
            "field_name": "start_date",
            "strategy": "date_relative",
            "params": {
              "anchor": "today",
              "min_offset_days": -900,
              "max_offset_days": -30
            }
          },
          {
            "field_name": "end_date",
            "strategy": "static_list",
            "params": {
              "values": [
                null
              ],
              "sampling": "cycle"
            }
          }
        ]
      },
      {
        "name": "Salary",
        "row_count_default": 12,
        "notes": "Salary: amount as money-compatible number; effective_from required",
        "tenant_scoped": false,
        "field_patterns": [
          {
            "field_name": "id",
            "strategy": "uuid_generate",
            "params": {}
          },
          {
            "field_name": "person",
            "strategy": "foreign_key",
            "params": {
              "target_entity": "Person"
            }
          },
          {
            "field_name": "amount",
            "strategy": "currency_amount",
            "params": {
              "min": 35000,
              "max": 120000,
              "currency": "GBP"
            }
          },
          {
            "field_name": "effective_from",
            "strategy": "date_relative",
            "params": {
              "anchor": "today",
              "min_offset_days": -800,
              "max_offset_days": -14
            }
          },
          {
            "field_name": "effective_to",
            "strategy": "static_list",
            "params": {
              "values": [
                null
              ],
              "sampling": "cycle"
            }
          },
          {
            "field_name": "reason",
            "strategy": "enum_weighted",
            "params": {
              "enum_values": [
                "new_hire",
                "promotion",
                "market_adjustment",
                "annual_review",
                "correction"
              ],
              "weights": [
                0.3,
                0.25,
                0.2,
                0.2,
                0.05
              ]
            }
          }
        ]
      },
      {
        "name": "ManagerLink",
        "row_count_default": 8,
        "notes": "Reporting lines",
        "tenant_scoped": false,
        "field_patterns": [
          {
            "field_name": "id",
            "strategy": "uuid_generate",
            "params": {}
          },
          {
            "field_name": "report",
            "strategy": "foreign_key",
            "params": {
              "target_entity": "Person"
            }
          },
          {
            "field_name": "manager",
            "strategy": "foreign_key",
            "params": {
              "target_entity": "Person"
            }
          },
          {
            "field_name": "start_date",
            "strategy": "date_relative",
            "params": {
              "anchor": "today",
              "min_offset_days": -900,
              "max_offset_days": -30
            }
          },
          {
            "field_name": "end_date",
            "strategy": "static_list",
            "params": {
              "values": [
                null
              ],
              "sampling": "cycle"
            }
          }
        ]
      }
    ]
  }
}
