{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dazzle.dev/schemas/scene_walk.schema.json",
  "title": "Dazzle scene walk",
  "description": "Deterministic persona walk: story-linked scenes with HTTP/Playwright actions. L2 between mechanical route smoke and LLM journey explore (#1638). api_* verbs are supported extension actions (#1639), not pilot-only refuse."
  "type": "object",
  "required": ["persona", "scenes"],
  "additionalProperties": true,
  "properties": {
    "persona": {
      "type": "string",
      "description": "DSL persona id (e.g. member, customer)"
    },
    "email_env": {
      "type": "string",
      "description": "Env var for login email (prefer framework magic-link / QA session)"
    },
    "password_env": {
      "type": "string",
      "description": "Env var for login password"
    },
    "rhythm": { "type": "string" },
    "phase": { "type": "string" },
    "home_workspace": { "type": "string" },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/scene" }
    }
  },
  "$defs": {
    "scene": {
      "type": "object",
      "required": ["id", "actions"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string" },
        "story": {
          "type": "string",
          "description": "Story id from DSL (e.g. ST-020); optional but preferred"
        },
        "entry": {
          "type": "string",
          "description": "App path template; may include {vars}"
        },
        "expects": { "type": "string" },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/action" }
        }
      }
    },
    "action": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "navigate",
            "assert_not_login",
            "assert_http_ok",
            "assert_http_ok_or_empty",
            "assert_http_ok_or_forbidden",
            "assert_no_server_error",
            "assert_no_error_banner",
            "assert_any_text",
            "assert_has_dz_or_content",
            "api_find",
            "api_ensure_status",
            "api_assert_field",
            "api_post",
            "api_upload_file",
            "api_agent_ensure_el_viewed",
            "playwright_click",
            "playwright_wait"
          ]
        },
        "texts": {
          "type": "array",
          "items": { "type": "string" }
        },
        "entry": { "type": "string" },
        "path": { "type": "string" },
        "role": { "type": "string" },
        "name": { "type": "string" }
      }
    }
  }
}
