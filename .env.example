# Dazzle Environment Variables
# Copy to .env and fill in your values

# Database (required). On Linux (Debian/Ubuntu) include user:password and use
# 127.0.0.1 — the credential-less form only works on Homebrew Postgres (macOS).
# See docs/reference/databases.md for per-OS setup.
DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/myapp

# LLM provider (not needed inside Claude Code — only for standalone use)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Redis (optional — needed for async tasks)
# REDIS_URL=redis://localhost:6379/0
