{
  "permissions": {
    "allow": [
      "WebSearch",

      "Bash(dazzle:*)",
      "Bash(python -m dazzle:*)",

      "Bash(pytest:*)",
      "Bash(python -m pytest:*)",
      "Bash(python -B -m pytest:*)",
      "Bash(DAZZLE_SKIP_INFRA_CHECK=1 python -m pytest:*)",
      "Bash(DAZZLE_SKIP_INFRA_CHECK=1 timeout * python -m pytest:*)",
      "Bash(DATABASE_URL=* python -m pytest:*)",
      "Bash(DATABASE_URL=* pytest:*)",

      "Bash(ruff:*)",
      "Bash(python -m ruff:*)",
      "Bash(mypy:*)",
      "Bash(python -m mypy:*)",
      "Bash(python -m build:*)",
      "Bash(twine:*)",
      "Bash(pre-commit:*)",

      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(node:*)",
      "Bash(npx:*)",
      "Bash(npm:*)",

      "Bash(pip:*)",

      "Bash(git:*)",
      "Bash(gh:*)",

      "Bash(docker:*)",

      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(http:*)",
      "Bash(jq:*)",

      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(which:*)",
      "Bash(pwd)",
      "Bash(env)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(chmod:*)",
      "Bash(xargs:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(diff:*)",
      "Bash(du:*)",
      "Bash(tr:*)",
      "Bash(awk:*)",
      "Bash(sed:*)",
      "Bash(tar:*)",
      "Bash(zip:*)",
      "Bash(unzip:*)",
      "Bash(sqlite3:*)",
      "Bash(test:*)",
      "Bash(stat:*)",
      "Bash(wait)",

      "mcp__dazzle__*",

      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:playwright.dev)",
      "WebFetch(domain:fastapi.tiangolo.com)",
      "WebFetch(domain:pypi.org)",
      "WebFetch(domain:docs.pydantic.dev)",
      "WebFetch(domain:htmx.org)",
      "WebFetch(domain:cdn.jsdelivr.net)",
      "WebFetch(domain:unpkg.com)",
      "WebFetch(domain:www.npmjs.com)",
      "WebFetch(domain:docs.brew.sh)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:deepwiki.com)",
      "WebFetch(domain:gofastmcp.com)",
      "WebFetch(domain:modelcontextprotocol.github.io)",
      "WebFetch(domain:caniuse.com)",

      "Read(//*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(sudo:*)",
      "Bash(su :*)",
      "Bash(chmod -R 777:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(fdisk:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session_start.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/bash_validator.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/file_protection.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/dsl_validator.py",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
