      "title": "Team Member",
      "intent": "A person with an account who can create and be assigned tasks within an organisation",
      "lifecycle_states": [],
      "relationships": []
    },
    {
      "name": "Task",
      "title": "Task",
      "intent": "A unit of work assigned to a Team Member with a lifecycle from todo through review to done",
      "lifecycle_states": [
        "todo",
        "in_progress",
        "review",
        "done"
      ],
      "relationships": [
        {
          "field": "assigned_to",
          "target": "User",
          "target_title": "Team Member",
          "required": false
        },
        {
          "field": "created_by",
          "target": "User",
          "target_title": "Team Member",
          "required": false
        }
      ]
    },
    {
      "name": "TaskComment",
      "title": "Task Comment",
      "intent": "A discussion note attached to a Task by a Team Member to capture context or decisions",
      "lifecycle_states": [],
      "relationships": [
        {
          "field": "task",
          "target": "Task",
          "target_title": "Task",
          "required": true
        },
        {
          "field": "author",
          "target": "User",
          "target_title": "Team Member",
          "required": true
        }
      ]
